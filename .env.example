# Copy this file to `.env` and fill in real values.
# Never commit your real `.env` file or paste API keys into frontend code.

# OpenAI
# Get your API key from:
# https://platform.openai.com/api-keys
# Help article:
# https://help.openai.com/en/articles/4936850-where-do-i-find-my-openai-api-key
OPENAI_API_KEY=sk-your-openai-api-key

# Optional model settings
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# LangSmith observability
# Sign up / open LangSmith:
# https://smith.langchain.com/
# Docs:
# https://docs.smith.langchain.com/
# Create a LangSmith API key from your LangSmith account settings, then paste it here.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_your_langsmith_api_key
LANGSMITH_PROJECT=multi-agent-research-system

# Optional Helicone observability proxy
# Get your Helicone API key from:
# https://docs.helicone.ai/
# Auth docs:
# https://docs.helicone.ai/helicone-headers/helicone-auth
HELICONE_ENABLED=false
HELICONE_API_KEY=your_helicone_api_key
